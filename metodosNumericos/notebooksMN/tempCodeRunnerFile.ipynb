import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
from scipy.signal import savgol_filter

sns.set_theme(style="whitegrid")

STUDENT_ID = 5657

t = np.linspace(0, 2 * np.pi, 600)
a = 1.0
k = 0.5
r = a * (1 - np.cos(t))**k
x = r * np.cos(t)
y = r * np.sin(t)

# Rotación para orientar la cardioide de frente
theta = np.pi / 2
x_rot = x * np.cos(theta) - y * np.sin(theta)
y_rot = x * np.sin(theta) + y * np.cos(theta)
x, y = x_rot, y_rot

plt.figure(figsize=(6, 6))
plt.plot(x, y, color="teal", linewidth=2, label="Cardioide ideal")
plt.title("Forma ideal (Ground Truth)")
plt.xlabel("x")
plt.ylabel("y")
plt.axis("equal")
plt.grid(True)
plt.legend()
plt.show()

np.random.seed(STUDENT_ID)

ruido = np.random.normal(loc=0.0, scale=0.5, size=len(x))
x_ruidoso = x + ruido
y_ruidoso = y + ruido

nan_idx = np.random.choice(len(x), size=15, replace=False)
x_ruidoso[nan_idx] = np.nan
y_ruidoso[nan_idx] = np.nan

out_idx = np.random.choice(len(x), size=5, replace=False)
x_ruidoso[out_idx] = 3 * x_ruidoso[out_idx]
y_ruidoso[out_idx] = 3 * y_ruidoso[out_idx]

df_raw = pd.DataFrame({"x": x_ruidoso, "y": y_ruidoso})
df_raw.to_csv("datos_degradados.csv", index=False)

df_raw = pd.read_csv("datos_degradados.csv")

df_raw.info()
df_raw.describe()

faltantes = df_raw.isna().sum()
print("\n--- Datos faltantes por columna ---")
print(faltantes)

num_cols = df_raw.select_dtypes(include="number")
fuera_rango = (num_cols < -20) | (num_cols > 20)
print("\n--- Valores fuera de rango por columna ---")
print(fuera_rango.sum())

x_col = "x"
y_col = "y"

plt.figure(figsize=(6, 6))
plt.scatter(df_raw[x_col], df_raw[y_col], s=15, alpha=0.6, color="teal")
plt.title("Datos crudos: dispersión")
plt.xlabel(x_col)
plt.ylabel(y_col)
plt.axis("equal")
plt.grid(True)
plt.show()

df_clean = df_raw.copy()
umbral = 25
df_clean.loc[df_clean["x"].abs() > umbral, "x"] = np.nan
df_clean.loc[df_clean["y"].abs() > umbral, "y"] = np.nan

df_clean["x"] = df_clean["x"].interpolate(method="linear", limit_direction="both")
df_clean["y"] = df_clean["y"].interpolate(method="linear", limit_direction="both")

# Suavizado avanzado: mediana, media y Savitzky-Golay mejorado
df_med = df_clean.rolling(window=11, center=True).median()
df_mean = df_med.rolling(window=31, center=True).mean()
df_sg = df_mean.copy()

window_length = 61  # Debe ser impar y menor que el número de puntos
polyorder = 5

df_sg["x"] = savgol_filter(df_mean["x"].fillna(method="bfill").fillna(method="ffill"), window_length=window_length, polyorder=polyorder)
df_sg["y"] = savgol_filter(df_mean["y"].fillna(method="bfill").fillna(method="ffill"), window_length=window_length, polyorder=polyorder)
df_sg = df_sg.dropna()

print("Limpieza y reconstrucción completadas.")
print(df_sg.head())

fig, axes = plt.subplots(1, 2, figsize=(12, 5))

axes[0].scatter(df_raw["x"], df_raw["y"], s=15, alpha=0.6, color="red", label="Datos crudos")
axes[0].set_title("PRE-PROCESAMIENTO")
axes[0].set_xlabel("x")
axes[0].set_ylabel("y")
axes[0].axis("equal")
axes[0].grid(True)
axes[0].legend()

axes[1].plot(x, y, linestyle="--", color="black", linewidth=1.5, label="Ideal")
axes[1].plot(df_sg["x"], df_sg["y"], color="green", linewidth=2, label="Reconstruida")
axes[1].set_title("POST-PROCESAMIENTO")
axes[1].set_xlabel("x")
axes[1].set_ylabel("y")
axes[1].axis("equal")
axes[1].grid(True)
axes[1].legend()

plt.tight_layout()
plt.show()