{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compilar C++ (archivo actual)",
      "type": "shell",
      "command": "New-Item -ItemType Directory -Force -Path \"${workspaceFolder}\\.vscode\\bin\\${relativeFileDirname}\" | Out-Null; g++ -std=c++20 -Wall -Wextra -pthread -g \"${file}\" -o \"${workspaceFolder}\\.vscode\\bin\\${relativeFileDirname}\\${fileBasenameNoExtension}.exe\"",
      "group": {
        "kind": "build",
        "isDefault": false
      },
      "problemMatcher": ["$gcc"]
    },
    {
      "label": "Ejecutar C++ (archivo actual)",
      "type": "shell",
      "command": "& '${workspaceFolder}\\.vscode\\bin\\${relativeFileDirname}\\${fileBasenameNoExtension}.exe'; Remove-Item '${workspaceFolder}\\.vscode\\bin\\${relativeFileDirname}\\${fileBasenameNoExtension}.exe' -ErrorAction SilentlyContinue",
      "dependsOn": "Compilar C++ (archivo actual)",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "focus": true
      },
      "problemMatcher": []
    }
  ]
}
